msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:460
msgid "**Cause:** `staticwebapp.config.json` missing or not deployed."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:462
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:462"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:464
msgid ""
"# Verify file exists in source\n"
"ls -la packages/frontend/public/staticwebapp.config.json\n"
"\n"
"# File must be in public/ to be copied to dist/ during build\n"
"\n"
"# If missing, create it:\n"
"cat > packages/frontend/public/staticwebapp.config.json << 'EOF'\n"
"{\n"
"  \"navigationFallback\": {\n"
"    \"rewrite\": \"/index.html\",\n"
"    \"exclude\": [\"/assets/*\", \"/*.js\", \"/*.css\", \"/*.json\"]\n"
"  }\n"
"}\n"
"EOF\n"
"\n"
"# Commit and redeploy\n"
"git add packages/frontend/public/staticwebapp.config.json\n"
"git commit -m \"fix: add SPA routing configuration\"\n"
"git push origin acc"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:486
msgid "Environment variables not applied"
msgstr ""

