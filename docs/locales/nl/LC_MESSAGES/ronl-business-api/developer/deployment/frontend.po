msgid "**Symptoms:** App loads but can't connect to Keycloak or API."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:490
msgid "**Cause:** Build-time environment variables not set."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:492
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:492"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:494
msgid ""
"# Check GitHub Secrets are configured\n"
"# Repository → Settings → Secrets and variables → Actions\n"
"\n"
"# Required secrets:\n"
"# - ACC_KEYCLOAK_URL\n"
"# - ACC_API_URL\n"
"\n"
"# Verify workflow uses them:\n"
"# .github/workflows/azure-frontend-acc.yml\n"
"env:\n"
"  VITE_KEYCLOAK_URL: ${{ secrets.ACC_KEYCLOAK_URL }}\n"
"  VITE_API_URL: ${{ secrets.ACC_API_URL }}\n"
"\n"
"# Re-run workflow after fixing"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:511
msgid "CORS errors in browser console"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:513
msgid "**Symptoms:** Browser shows CORS policy errors when calling API."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:515
msgid "**Cause:** Keycloak or API not configured for frontend origin."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:517
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:517"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:519
msgid ""
"# Keycloak: Web Origins should be '+'\n"
"# This inherits all Valid Redirect URIs as allowed origins\n"
"\n"
"# API: Backend must allow frontend origin in CORS config\n"
"# packages/backend/src/index.ts\n"
"app.use(cors({\n"
"  origin: [\n"
"    'https://acc.mijn.open-regels.nl',\n"
"    'https://mijn.open-regels.nl'\n"
"  ],\n"
"  credentials: true\n"
"}));"
msgstr ""

