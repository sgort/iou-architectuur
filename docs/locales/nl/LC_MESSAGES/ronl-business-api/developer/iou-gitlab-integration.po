msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ciou-gitlab-integration.md:96
msgid ""
"The IOU tab is rendered only when `leftPanelSections.iou` is present in the "
"tenant's `tenants.json` entry. To enable it for a tenant, add:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ciou-gitlab-integration.md:97
msgid ""
"\"iou\": [\n"
"  { \"id\": \"iou-gebruiksscenario\", \"label\": \"Gebruiksscenario "
"indienen\", \"isPublic\": false },\n"
"  { \"id\": \"iou-feedback\",         \"label\": \"Feedback "
"geven\",            \"isPublic\": false },\n"
"  { \"id\": \"iou-actieve-zaken\",    \"label\": \"Actieve "
"zaken\",             \"isPublic\": true  },\n"
"  { \"id\": \"iou-archief\",          \"label\": "
"\"Archief\",                   \"isPublic\": true  }\n"
"]"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ciou-gitlab-integration.md:106
msgid ""
"The `isPublic: true` sections (`iou-actieve-zaken`, `iou-archief`) are "
"visible without login. The submission sections require authentication."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ciou-gitlab-integration.md:110
msgid "Adding a new IOU section"
