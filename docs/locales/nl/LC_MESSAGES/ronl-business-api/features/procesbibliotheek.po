msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cfeatures%5Cprocesbibliotheek.md:33
msgid "Linked document templates (by `ronl:documentRef`)"
msgstr ""

