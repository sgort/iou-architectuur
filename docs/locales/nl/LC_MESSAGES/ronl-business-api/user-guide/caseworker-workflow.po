#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cuser-guide%5Ccaseworker-workflow.md:86
msgid "AWB Kapvergunning — full process flow"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cuser-guide%5Ccaseworker-workflow.md:88
msgid ""
"The tree felling permit is an asynchronous, multi-actor process. The citizen "
"submits an application and the process runs automatically through three "
"preparatory phases before suspending at the first caseworker task. A second "
"suspension follows before the process ends. The diagram below shows the "
"complete flow across all participants."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cuser-guide%5Ccaseworker-workflow.md:90
msgid ""
"sequenceDiagram\n"
"    participant C as Citizen (Frontend)\n"
"    participant B as Business API\n"
"    participant O as Operaton\n"
"    participant CW as Caseworker (Frontend)\n"
"    participant D as PostgreSQL\n"
"\n"
"    C->>B: POST /v1/process/AwbShellProcess/start<br/>(treeDiameter, "
"protectedArea)\n"
"    B->>B: Validate JWT, inject tenant variables\n"
"    B->>O: POST /process-definition/key/AwbShellProcess/start\n"
"    O->>O: Phase 1 — set applicantId, productType, applicationDate\n"
"    O->>O: Phase 2 — set receiptDate, awbDeadlineDate, dossierReference\n"
"    O->>O: Phase 3 — evaluate AwbCompletenessCheck DMN\n"
"    O->>O: Call Activity → TreeFellingPermitSubProcess\n"
"    O->>O: Evaluate TreeFellingDecision DMN → permitDecision\n"
"    O->>O: Evaluate ReplacementTreeDecision DMN → replacementDecision\n"
"    O-->>O: Create user task: Sub_CaseReview\n"
"    B->>D: Write audit log entry\n"
"    B->>C: Return { processInstanceId, dossierReference }\n"
"\n"
"    Note over O: Process suspended — awaiting caseworker\n"
"\n"
"    CW->>B: GET /v1/task\n"
"    B->>O: GET /task?processVariables=municipality_eq_utrecht\n"
"    O->>B: Return task list\n"
"    B->>CW: Return open tasks\n"
"\n"
"    CW->>B: POST /v1/task/:id/claim\n"
"    B->>O: POST /task/:id/claim\n"
"    CW->>B: POST /v1/task/:id/complete<br/>(reviewAction, "
"reviewPermitDecision?)\n"
"    B->>O: POST /task/:id/complete\n"
"    O->>O: Set final status, decisionType, finalMessage\n"
"    O-->>O: Create user task: Task_Phase6_Notify\n"
"\n"
"    Note over O: Process suspended — awaiting notification confirmation\n"
"\n"
"    CW->>B: POST /v1/task/:id/complete<br/>(notificationMethod, "
"applicantNotified)\n"
"    B->>O: POST /task/:id/complete\n"
"    O->>O: Phase 6 complete — process ends\n"
"    B->>D: Write audit log entry"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cuser-guide%5Ccaseworker-workflow.md:133
