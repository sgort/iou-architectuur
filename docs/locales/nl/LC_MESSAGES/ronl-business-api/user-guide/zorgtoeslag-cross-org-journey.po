msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cuser-guide%5Czorgtoeslag-cross-org-journey.md:31
msgid ""
"Click the **Zorgtoeslag** service card. The zorgtoeslag view opens with a "
"calculator card and an Aanvragen button."
msgstr ""

