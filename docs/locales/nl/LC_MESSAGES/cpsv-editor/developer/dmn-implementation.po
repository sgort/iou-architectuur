"\n"
"  // Deployment\n"
"  decisionKey: string,          // Primary key extracted from DMN\n"
"  deployed: boolean,\n"
"  deploymentId: string | null,\n"
"  deployedAt: string | null,\n"
"\n"
"  // API\n"
"  apiEndpoint: string,\n"
"\n"
"  // Testing\n"
"  lastTestResult: object | null,\n"
"  lastTestTimestamp: string | null,\n"
"  testBody: string | null,\n"
"\n"
"  // Import preservation (v1.5.1+)\n"
"  importedDmnBlocks: string | null,  // Raw Turtle lines preserved verbatim\n"
"  isImported: boolean,\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:60
msgid "Syntactic validation"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:62
msgid "Overview"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:64
msgid ""
"When a DMN file is uploaded or an example is loaded, `DMNTab.jsx` calls the "
"shared backend validation endpoint and stores the result in local component "
"state."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:66
msgid ""
"// State added in v1.9.3\n"
"const [validationResult, setValidationResult] = useState(null);\n"
"const [isValidating, setIsValidating]         = useState(false);\n"
"const [validationExpanded, setValidationExpanded] = useState(false);"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:73
msgid "Backend call"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:75
msgid ""
"const runBackendValidation = async (content) => {\n"
"  setIsValidating(true);\n"
"  try {\n"
"    const response = await fetch(\n"
"      `${process.env.REACT_APP_BACKEND_URL}/v1/dmns/validate`,\n"
"      {\n"
"        method: 'POST',\n"
"        headers: { 'Content-Type': 'application/json' },\n"
"        body: JSON.stringify({ content }),\n"
"      }\n"
"    );\n"
"    const data = await response.json();\n"
"    if (data.success) {\n"
"      setValidationResult(data.data);\n"
"      // Auto-expand the panel when errors are present\n"
"      setValidationExpanded(data.data.summary.errors > 0);\n"
"    }\n"
"  } catch (err) {\n"
"    // Validation failure is non-blocking — DMN workflow continues\n"
"  } finally {\n"
"    setIsValidating(false);\n"
"  }\n"
"};"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:101
msgid "The call is made:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:103
msgid "After `handleFileUpload` — `reader.onload` completes"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:104
msgid "After `loadExampleDMN` — on successful fetch"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:105
msgid ""
"Cleared in `handleClearFile` — `setValidationResult(null); setIsValidating"
"(false);`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:107
msgid "Validation is non-blocking"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:109
msgid ""
"A validation failure (network error or backend unavailable) does not prevent "
"the DMN workflow from continuing. The panel simply does not appear. This "
"ensures the editor remains functional in environments where the backend is "
"unreachable."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:111
msgid "Response shape"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:113
msgid ""
"interface ValidationResult {\n"
"  valid: boolean;\n"
"  parseError: string | null;\n"
"  layers: {\n"
"    base:        { label: string; issues: Issue[] };\n"
"    business:    { label: string; issues: Issue[] };\n"
"    execution:   { label: string; issues: Issue[] };\n"
"    interaction: { label: string; issues: Issue[] };\n"
"    content:     { label: string; issues: Issue[] };\n"
"  };\n"
"  summary: { errors: number; warnings: number; infos: number };\n"
"}\n"
"\n"
"interface Issue {\n"
"  severity: 'error' | 'warning' | 'info';\n"
"  code: string;      // e.g. 'EXEC-001', 'INT-005'\n"
"  message: string;\n"
"  location?: string; // element description e.g. '<decision id=\"d1\">'\n"
"  line?: number;\n"
"  column?: number;\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:137
msgid "UI rendering"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:139
msgid ""
"The validation panel is rendered inside the file card, between the file info "
"row and the Deploy button. It is hidden when `validationResult` is null or "
"`isValidating` is true (a spinner is shown instead)."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:141
msgid ""
"The collapsible layer rows follow the same pattern as the Linked Data "
"Explorer's `DmnValidator` component — each layer shows an icon and badge "
"counts at a glance and expands on click to show individual issue rows."
msgstr ""

