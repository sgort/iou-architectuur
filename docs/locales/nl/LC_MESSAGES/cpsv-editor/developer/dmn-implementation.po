#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:147
msgid "Detection"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:149
msgid ""
"`vocabularies_config.js` detects DMN entities before regular entities to "
"avoid misclassification:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:151
msgid ""
"export const detectEntityType = (line) => {\n"
"  // DMN detection FIRST\n"
"  if (line.includes('a cprmv:DecisionModel')) return 'dmnModel';\n"
"  if (line.includes('a cpsv:Input'))          return 'dmnInput';\n"
"  if (line.includes('a cprmv:DecisionRule'))  return 'dmnRule';\n"
"\n"
"  // Regular entity detection below...\n"
"};"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:162
msgid "Capture"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:164
msgid "`parseTTL.enhanced.js` captures DMN lines verbatim when detected:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cdmn-implementation.md:166
msgid ""
"let inDmnSection = false;\n"
"let dmnLines = [];\n"
"\n"
"if (['dmnModel', 'dmnInput', 'dmnRule'].includes(detectedType)) {\n"
"  if (!inDmnSection) {\n"
"    inDmnSection = true;\n"
"    parsed.hasDmnData = true;\n"
"  }\n"
"  dmnLines.push(rawLine);  // exact line, no transformation\n"
"  continue;\n"
"}\n"
"\n"
"if (parsed.hasDmnData && dmnLines.length > 0) {\n"
"  parsed.importedDmnBlocks = dmnLines.join('\\n');\n"
"}"
msgstr ""

