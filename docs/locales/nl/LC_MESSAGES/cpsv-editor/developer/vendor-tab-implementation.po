#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:24
msgid "Vendors are loaded from TriplyDB via SPARQL:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:26
msgid ""
"PREFIX ronl: <https://regels.overheid.nl/termen/>\n"
"SELECT ?vendor ?label WHERE {\n"
"  ?vendor a ronl:MethodConcept ;\n"
"          skos:prefLabel ?label .\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:34
msgid ""
"Endpoint: `https://api.open-regels.triply.cc/datasets/stevengort/ronl/"
"services/ronl/sparql`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:36
msgid ""
"Vendor URIs follow the pattern `https://regels.overheid.nl/termen/"
"{VendorName}`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:40
msgid "Vendor state shape"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:42
msgid ""
"vendorService: {\n"
"  selectedVendor: string,         // Vendor URI\n"
"  serviceTitle: string,\n"
"  contact: {\n"
"    contactPerson: string,\n"
"    email: string,\n"
"    phone: string,\n"
"    website: string,\n"
"    logo: string | null,          // Base64 encoded image\n"
"  },\n"
"  technical: {\n"
"    serviceUrl: string,\n"
"    license: string,\n"
"    accessType: string,\n"
"  },\n"
"  serviceNotes: string,\n"
"  certification: {\n"
"    status: string,               // 'not-certified' | 'self-assessed' | "
"'certified'\n"
"    certifiedBy: string,          // Organisation URI\n"
"    certifiedAt: string,          // ISO date\n"
"    certificationNote: string,\n"
"  }\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:70
msgid "TTL output"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:72
msgid "The generated Turtle for a vendor service:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvendor-tab-implementation.md:74
msgid ""
"<https://regels.overheid.nl/vendor-services/{vendor}/{serviceId}>\n"
"    a ronl:VendorService ;\n"
"    dct:title \"{serviceTitle}\"@nl ;\n"
"    ronl:basedOn <https://regels.overheid.nl/services/{serviceId}> ;\n"
"    ronl:implementedBy <{vendorUri}> ;\n"
"    schema:provider [\n"
"        a schema:Organization ;\n"
"        schema:name \"{vendorName}\" ;\n"
"        schema:image <./assets/{VendorName}_vendor_logo.png> ;\n"
"        schema:contactPoint [\n"
"            schema:name \"{contactPerson}\" ;\n"
"            schema:email \"{email}\" ;\n"
"            schema:telephone \"{phone}\"\n"
"        ] ;\n"
"        foaf:homepage <{website}>\n"
"    ] ;\n"
"    schema:url <{serviceUrl}> ;\n"
"    schema:license \"{license}\" ;\n"
"    ronl:certificationStatus \"{status}\"^^xsd:string ;\n"
"    ronl:certifiedBy <{certifiedByUri}> ;\n"
"    ronl:certifiedAt \"{date}\"^^xsd:date ."
msgstr ""

