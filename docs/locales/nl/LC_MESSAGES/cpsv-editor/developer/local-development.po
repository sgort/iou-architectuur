msgid "Deploying to ACC"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Clocal-development.md:108
msgid ""
"# 1. Commit your changes\n"
"git add .\n"
"git commit -m \"feat: your change description\"\n"
"\n"
"# 2. Push to ACC branch\n"
"git push origin acc\n"
"\n"
"# 3. Monitor the GitHub Actions workflow\n"
"# https://github.com/your-org/cpsv-editor/actions\n"
"\n"
"# 4. Verify the ACC deployment\n"
"curl https://acc.cpsv-editor.open-regels.nl"
msgstr ""
