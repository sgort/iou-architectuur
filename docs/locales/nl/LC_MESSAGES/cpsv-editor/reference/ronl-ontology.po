#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:56
msgid ""
"The following rules apply when producing or validating Turtle using these "
"properties:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:58
msgid ""
"If `ronl:validationStatus` is `\"validated\"`, then `ronl:validatedBy` and "
"`ronl:validatedAt` must be present."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:60
msgid ""
"If `ronl:certificationStatus` is `\"certified\"`, then `ronl:certifiedBy` "
"and `ronl:certifiedAt` must be present, and `ronl:certifiedAt` must be on or "
"after `ronl:validatedAt`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:62
msgid ""
"If a subject has `ronl:certifiedBy`, it must also have `ronl:basedOn` "
"(certified vendor services must reference a canonical service for "
"traceability)."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:66
msgid "Example: Reference DMN validation"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:68
msgid ""
"@prefix ronl:  <https://regels.overheid.nl/ontology#> .\n"
"@prefix cprmv: <https://cprmv.open-regels.nl/0.3.0/> .\n"
"@prefix dct:   <http://purl.org/dc/terms/> .\n"
"\n"
"<https://regels.overheid.nl/services/aow-leeftijd/dmn>\n"
"    a cprmv:DecisionModel ;\n"
"    dct:identifier \"SVB_LeeftijdsInformatie\" ;\n"
"    dct:title \"SVB Leeftijdsinformatie DMN\"@nl ;\n"
"    cprmv:implements <https://regels.overheid.nl/services/aow-leeftijd> ;\n"
"    ronl:validatedBy <https://organisaties.overheid.nl/28212263/"
"Sociale_Verzekeringsbank> ;\n"
"    ronl:validationStatus \"validated\"^^xsd:string ;\n"
"    ronl:validatedAt \"2026-02-15\"^^xsd:date ;\n"
"    ronl:validationNote \"Validated against AOW legislation Article 7a. 127 "
"test cases passed.\"@nl ."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:86
msgid "Example: Vendor service certification"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Creference%5Cronl-ontology.md:88
msgid ""
"@prefix ronl:   <https://regels.overheid.nl/ontology#> .\n"
"@prefix cpsv:   <http://purl.org/vocab/cpsv#> .\n"
"@prefix dct:    <http://purl.org/dc/terms/> .\n"
"\n"
"<https://regels.overheid.nl/vendor-services/blueriq/aow-leeftijd>\n"
"    a cpsv:PublicService ;\n"
"    dct:identifier \"blueriq-aow-leeftijd\" ;\n"
"    dct:title \"AOW Leeftijd - Blueriq Implementation\"@nl ;\n"
"    ronl:basedOn <https://regels.overheid.nl/services/aow-leeftijd> ;\n"
"    ronl:validatedBy <https://regels.overheid.nl/vendors/blueriq> ;\n"
"    ronl:validationStatus \"validated\"^^xsd:string ;\n"
"    ronl:validatedAt \"2026-02-10\"^^xsd:date ;\n"
"    ronl:certifiedBy <https://organisaties.overheid.nl/28212263/"
"Sociale_Verzekeringsbank> ;\n"
"    ronl:certificationStatus \"certified\"^^xsd:string ;\n"
"    ronl:certifiedAt \"2026-02-15\"^^xsd:date ;\n"
"    ronl:certificationNote \"Meets SVB implementation requirements v2.1. "
"Annual recertification required.\"@nl ."
msgstr ""
