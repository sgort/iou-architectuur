#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:214
msgid ""
"# Inside Keycloak container\n"
"/opt/keycloak/bin/kc.sh export \\\n"
"  --dir /tmp/export \\\n"
"  --realm ronl \\\n"
