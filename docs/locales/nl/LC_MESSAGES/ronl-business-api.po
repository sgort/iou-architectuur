#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:63
msgid "Create `src/routes/myfeature.routes.ts` following the existing pattern:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:65
msgid ""
"import { Router, Request, Response } from 'express';\n"
"import { ApiResponse } from '@ronl/shared';\n"
"import logger from '@utils/logger';\n"
"\n"
"const router = Router();\n"
"\n"
"router.get('/', async (req: Request, res: Response) => {\n"
"  try {\n"
"    res.json({\n"
"      success: true,\n"
"      data: { ... },\n"
"      timestamp: new Date().toISOString(),\n"
"    } as ApiResponse);\n"
"  } catch (error) {\n"
"    logger.error('myfeature error', error);\n"
"    res.status(500).json({ success: false, error: { code: 'ERROR', message: "
"String(error) } });\n"
"  }\n"
"});\n"
"\n"
"export default router;"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:88
