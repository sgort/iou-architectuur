msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:352
msgid "Step 1 — Build locally"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:354
msgid ""
"cd ~/Development/ronl-business-api/packages/frontend\n"
"\n"
"# Set environment variables\n"
"export VITE_KEYCLOAK_URL=https://acc.keycloak.open-regels.nl\n"
"export VITE_API_URL=https://acc.api.open-regels.nl/v1\n"
"\n"
"# Build\n"
"npm run build\n"
"\n"
"# Output: dist/ directory\n"
"ls -la dist/"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:368
msgid "Step 2 — Deploy via Azure CLI"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:370
msgid ""
"# Install Azure CLI (if not installed)\n"
"curl -sL https://aka.ms/InstallAzureCLIDeb | sudo bash\n"
"\n"
"# Login to Azure\n"
"az login\n"
"\n"
"# Deploy to ACC\n"
"az staticwebapp deploy \\\n"
"  --name ronl-frontend-acc \\\n"
"  --resource-group rg-ronl-acc \\\n"
"  --source ./dist \\\n"
"  --no-use-keychain\n"
"\n"
"# Wait for deployment (~2-3 minutes)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:387
msgid "Step 3 — Verify"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:389
msgid ""
"# Test deployment\n"
"curl -I https://acc.mijn.open-regels.nl\n"
"# Should return: 200 OK\n"
"\n"
"# Open in browser\n"
"# Visit: https://acc.mijn.open-regels.nl"
msgstr ""

