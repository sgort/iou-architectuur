#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccopilot-studio-edocs.md:1
msgid "Copilot Studio — eDOCS OAuth Integration"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccopilot-studio-edocs.md:3
msgid ""
"This page documents how Microsoft Copilot Studio can connect to the eDOCS "
"document management system using OAuth 2.0 via the RONL Business API and "
"Keycloak."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccopilot-studio-edocs.md:7
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\copilot-studio-edocs.md:7"
msgid "Architecture"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccopilot-studio-edocs.md:9
msgid ""
"Copilot Studio never calls eDOCS directly. It authenticates against Keycloak "
"to obtain a Bearer token, then calls the RONL Business API which holds the "
"eDOCS credentials and proxies the request."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccopilot-studio-edocs.md:11
msgid ""
"Copilot Studio\n"
"    │\n"
"    │  1. POST /token  (client_credentials)\n"
"    ▼\n"
"Keycloak (acc.keycloak.open-regels.nl)\n"
"    │\n"
"    │  2. access_token (JWT, aud: ronl-business-api)\n"
"    ▼\n"
"Copilot Studio\n"
"    │\n"
"    │  3. GET /v1/edocs/*  Authorization: Bearer <token>\n"
"    ▼\n"
"RONL Business API (acc.api.open-regels.nl)\n"
"    │  jwtMiddleware validates token\n"
"    │\n"
"    │  4. proxies with eDOCS service credentials\n"
"    ▼\n"
"eDOCS DOCUVITT"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccopilot-studio-edocs.md:32
msgid ""
"The RONL Business API is the OAuth 2.0 resource server. Keycloak is the "
"authorisation server. Copilot Studio is the client."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccopilot-studio-edocs.md:36
msgid "eDOCS routes"
msgstr ""

