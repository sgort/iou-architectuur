msgid "Troubleshooting"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:581
msgid "Theme not appearing in dropdown"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:583
msgid ""
"**Symptoms:** Theme `ronl` not visible in Keycloak Admin Console theme "
"dropdown."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:585
msgid "**Cause:** Theme files not properly mounted or container not recreated."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:587
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\keycloak.md:587"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:589
msgid ""
"# Verify theme exists in container\n"
"docker exec keycloak-acc ls -la /opt/keycloak/themes/ronl/login/\n"
"\n"
"# Should show: login.ftl, theme.properties, resources/, messages/\n"
"\n"
"# If empty, check docker-compose.yml has volume mount\n"
"# Then recreate container\n"
"docker compose down\n"
"docker compose up -d"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:601
msgid "Theme selected but not applied"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:603
msgid ""
"**Symptoms:** Theme selected in Admin Console but still seeing default "
"Keycloak theme."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:605
msgid "**Cause:** Browser cache or theme not properly configured."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:607
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\keycloak.md:607"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:609
msgid ""
"# 1. Clear browser cache or use incognito mode\n"
"# 2. Verify theme is actually selected\n"
"# Admin Console → Realm Settings → Themes → Login Theme = ronl\n"
"\n"
"# 3. Check theme files are valid\n"
"docker exec keycloak-acc cat /opt/keycloak/themes/ronl/login/"
"theme.properties\n"
"\n"
"# Should contain:\n"
"# parent=base\n"
"# import=common/keycloak\n"
"# locales=nl,en\n"
"\n"
"# 4. Check logs for theme errors\n"
"docker compose logs keycloak-acc | grep -i theme"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:626
msgid "CSS not loading"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:628
msgid "**Symptoms:** Login page shows but styling is broken."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:630
msgid "**Cause:** CSS file permissions or path incorrect."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:632
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\keycloak.md:632"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:634
msgid ""
"# Check CSS file exists\n"
"docker exec keycloak-acc ls -la /opt/keycloak/themes/ronl/login/resources/"
"css/login.css\n"
"\n"
"# Check permissions (should be 644)\n"
"docker exec keycloak-acc stat /opt/keycloak/themes/ronl/login/resources/css/"
"login.css\n"
"\n"
"# If wrong, fix on VM:\n"
"sudo find /opt/keycloak/themes/ronl -type f -exec chmod 644 {} \\;\n"
"docker compose restart keycloak-acc"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:646
msgid "Caseworker banner not appearing"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:648
msgid ""
"**Symptoms:** Caseworker login shows generic Keycloak form without the "
"indigo banner or \"Medewerker portaal\" title."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:650
msgid ""
"**Cause 1:** Outdated `login.ftl` on the server — the sentinel detection "
"code is missing."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:652
msgid "**Solution:** Verify the installed template:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:653
msgid ""
"docker exec keycloak-acc grep -n 'isMedewerker' \\\n"
"  /opt/keycloak/themes/ronl/login/login.ftl\n"
"# Should return line numbers for the assign and if blocks"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:658
msgid ""
"If nothing is returned, redeploy the theme files and restart the container."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:660
msgid ""
"**Cause 2:** `sessionStorage` is not carrying `selected_idp = medewerker` to "
"`/auth`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:662
msgid ""
"**Solution:** Open DevTools → Application → Session Storage → `http://"
"localhost:5173` (or the ACC URL). Confirm `selected_idp` equals `medewerker` "
"before the `/auth` route is hit. If it is missing or a different value, the "
"`handleIDPSelection` call in `LoginChoice.tsx` is not firing correctly."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:664
msgid "Username field pre-filled with `__medewerker__`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:666
msgid ""
"**Symptoms:** The caseworker login form shows `__medewerker__` in the "
"username field."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:668
msgid ""
"**Cause:** The `login.ftl` on the server does not include the sentinel "
"suppression condition on the `value` attribute."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:670
msgid "**Solution:** The input must use:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:671
msgid "value=\"<#if !isMedewerker>${(login.username!'')}</#if>\""
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:674
msgid ""
"Ensure the deployed `login.ftl` matches the version in the repository and "
"restart the container."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:676
msgid "Dutch translations not working"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:678
msgid "**Symptoms:** Theme applied but text still in English."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:680
msgid "**Cause:** Locale not configured or messages file missing."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:682
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\keycloak.md:682"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:684
msgid ""
"# 1. Check messages file exists\n"
"docker exec keycloak-acc ls -la /opt/keycloak/themes/ronl/login/messages/"
"messages_nl.properties\n"
"\n"
"# 2. Verify realm localization settings\n"
"# Admin Console → Realm Settings → Localization\n"
"# - Internationalization: ON\n"
"# - Default Locale: nl\n"
"# - Supported Locales: nl, en (both checked)\n"
"\n"
"# 3. Check user's browser language preference\n"
"# Browser should be set to Dutch (nl-NL) or accept Dutch as preferred "
"language"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:698
msgid "Container unhealthy after restart"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:700
msgid "**Symptoms:** Container starts but health check fails."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:702
msgid "**Cause:** Database connection issues or Keycloak startup timeout."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:704
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\keycloak.md:704"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:706
msgid ""
"# Check database is running\n"
"docker ps | grep postgres-acc\n"
"\n"
"# Check database logs\n"
"docker compose logs keycloak-postgres-acc --tail 50\n"
"\n"
"# Check Keycloak logs for database connection errors\n"
"docker compose logs keycloak-acc | grep -i \"database\\|connection\\|jdbc\"\n"
"\n"
"# If database is healthy, increase health check timeout\n"
"# In docker-compose.yml:\n"
"healthcheck:\n"
"  start_period: 90s  # Increase from 60s"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:722
msgid "Realm not imported on first start"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:724
msgid "**Symptoms:** Keycloak starts but realm `ronl` doesn't exist."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:726
msgid "**Cause:** Realm file not mounted or import flag missing."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:728
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\keycloak.md:728"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:730
msgid ""
"# Check realm file is mounted\n"
"docker exec keycloak-acc ls -la /opt/keycloak/data/import/\n"
"\n"
"# Should show: ronl-realm.json\n"
"\n"
"# Check command includes import flag\n"
"# In docker-compose.yml command section:\n"
"command:\n"
"  - start-dev\n"
"  - --import-realm  # Must be present\n"
"\n"
"# Manually import if needed\n"
"docker exec keycloak-acc /opt/keycloak/bin/kc.sh import \\\n"
"  --file /opt/keycloak/data/import/ronl-realm.json"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:749
