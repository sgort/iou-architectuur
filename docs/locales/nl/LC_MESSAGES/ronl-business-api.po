msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cstandards-compliance.md:7
msgid ""
"Data minimisation (BSN encrypted, not logged in plaintext), audit trail (7-"
"year retention), purpose limitation (process variables scoped to the "
"requesting service)."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cstandards-compliance.md:7
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\references\\standards-compliance.md:7"
msgid "**DigiD Norm**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cstandards-compliance.md:7
msgid ""
"Authentication assurance levels (LoA) for citizen-facing services. RONL "
"enforces LoA checks on sensitive endpoints via the `loa` JWT claim."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cstandards-compliance.md:7
msgid "**NCSC Beveiligingsrichtlijnen**"
