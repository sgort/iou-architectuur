#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:199
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\operaton-mcp-client.md:199"
msgid "1. Obtain a token"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:201
msgid ""
"TOKEN=$(curl -s -X POST \\\n"
"  https://acc.keycloak.open-regels.nl/realms/ronl/protocol/openid-connect/"
"token \\\n"
"  -H \"Content-Type: application/x-www-form-urlencoded\" \\\n"
"  -d \"grant_type=client_credentials\" \\\n"
"  -d \"client_id=operaton-mcp-client\" \\\n"
"  -d \"client_secret=<secret-from-keycloak>\" \\\n"
"  | jq -r .access_token)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:211
msgid "2. Verify the token claims"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:213
msgid ""
"echo $TOKEN | cut -d. -f2 | base64 -d 2>/dev/null | jq '{aud, azp, sub}'"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:217
msgid ""
"Expected: `aud` contains `ronl-business-api`, `azp` is `operaton-mcp-"
"client`, no `municipality` claim."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:219
msgid "3. List all tasks (unfiltered across all organisations)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:221
msgid ""
"curl -s https://acc.api.open-regels.nl/v1/m2m/task \\\n"
"  -H \"Authorization: Bearer $TOKEN\" | jq ."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:226
msgid "4. List all active process instances"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:228
msgid ""
"curl -s https://acc.api.open-regels.nl/v1/m2m/process \\\n"
"  -H \"Authorization: Bearer $TOKEN\" | jq ."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:233
msgid "5. Evaluate a decision"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:235
msgid ""
"curl -s -X POST \\\n"
"  https://acc.api.open-regels.nl/v1/m2m/decision/TreeFellingDecision/"
"evaluate \\\n"
"  -H \"Authorization: Bearer $TOKEN\" \\\n"
"  -H \"Content-Type: application/json\" \\\n"
"  -d '{\"variables\": {\"treeDiameter\": 45, \"protectedArea\": false}}' \\\n"
"  | jq ."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:244
msgid "6. Get process history (body forwarded to Operaton)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:246
msgid ""
"curl -s -X GET \\\n"
"  https://acc.api.open-regels.nl/v1/m2m/process/history \\\n"
"  -H \"Authorization: Bearer $TOKEN\" \\\n"
"  -H \"Content-Type: application/json\" \\\n"
"  -d '{\"sorting\": [{\"sortBy\": \"startTime\", \"sortOrder\": \"desc\"}]}' "
"\\\n"
"  | jq ."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:255
msgid "7. Confirm tenant-scoped routes are still blocked"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:257
msgid ""
"curl -s https://acc.api.open-regels.nl/v1/task \\\n"
"  -H \"Authorization: Bearer $TOKEN\" | jq .error"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Coperaton-mcp-client.md:262
msgid ""
"Expected: `MISSING_TENANT` — the token carries no `municipality` claim so "
"`tenantMiddleware` rejects it, confirming the original caseworker routes "
"remain fully isolated."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:1
msgid "Shared Package"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:3
msgid ""
"`packages/shared` (`@ronl/shared`) contains TypeScript types and utilities "
"shared between the backend and frontend packages. It has no runtime "
"dependencies and must be built before either package can consume it."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:7
msgid "Build"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:9
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\shared-package.md:9"
msgid "npm run build --workspace=@ronl/shared"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:13
msgid ""
"Output is written to `packages/shared/dist/`. Both `@ronl/backend` and "
"`@ronl/frontend` reference `@ronl/shared: \"*\"` in their `package.json`, "
"resolving to the `dist/index.js` and `dist/index.d.ts` files."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:17
msgid "Contents"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:19
msgid ""
"The shared package exports the TypeScript types used across the system. Key "
"interfaces include:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:21
msgid ""
"**`ApiResponse<T>`** — standard response envelope used by all backend "
"endpoints:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:22
msgid ""
"interface ApiResponse<T = unknown> {\n"
"  success: boolean;\n"
"  data?: T;\n"
"  error?: { code: string; message: string; };\n"
"  timestamp: string;\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:31
msgid "**`TenantConfig`** — municipality tenant configuration shape:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:32
msgid ""
"interface TenantConfig {\n"
"  id: string;\n"
"  name: string;\n"
"  displayName: string;\n"
"  municipalityCode: string;\n"
"  theme: TenantTheme;\n"
"  features: TenantFeatures;\n"
"  contact: TenantContact;\n"
"  enabled: boolean;\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:45
msgid "**`JwtClaims`** — decoded JWT payload type for `req.user`:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:46
msgid ""
"interface JwtClaims {\n"
"  sub: string;\n"
"  municipality: string;\n"
"  roles: string[];\n"
"  loa: string;\n"
"  preferred_username: string;\n"
"  mandate?: string;\n"
"  bsn?: string;\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:60
msgid "Development workflow"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:62
msgid ""
"When you modify a type in `packages/shared/src/`, both the backend and "
"frontend need to pick up the change:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:64
msgid ""
"# Rebuild shared\n"
"npm run build --workspace=@ronl/shared\n"
"\n"
"# tsx watch (backend) and Vite HMR (frontend) pick up the rebuilt types "
"automatically\n"
"# If they don't, restart npm run dev"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cshared-package.md:72
msgid ""
"The pre-push Husky hook runs `npm run type-check` across all workspaces, "
"which catches type mismatches between shared types and their consumers "
"before the push reaches CI."
msgstr ""

