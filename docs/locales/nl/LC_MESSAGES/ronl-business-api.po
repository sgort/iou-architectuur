#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Coperaton.md:9
msgid ""
"Operaton deployment is managed directly on the VM. There is no Operaton-"
"specific folder in the `ronl-business-api` repository — Operaton's Docker "
"image and configuration are maintained separately from the application code."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Coperaton.md:13
msgid "Starting Operaton"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Coperaton.md:15
msgid ""
"ssh user@open-regels.nl\n"
"\n"
"# Create the Operaton directory\n"
"mkdir -p ~/operaton\n"
"cd ~/operaton\n"
"\n"
"# Create docker-compose.yml\n"
"cat > docker-compose.yml << 'EOF'\n"
"version: '3.8'\n"
"services:\n"
"  operaton:\n"
"    image: operaton/operaton:latest\n"
"    container_name: operaton\n"
"    ports:\n"
"      - \"127.0.0.1:8090:8080\"\n"
"    environment:\n"
"      - DB_DRIVER=org.h2.Driver\n"
"      - DB_URL=jdbc:h2:./camunda-h2-databases/process-"
"engine;TRACE_LEVEL_FILE=0;DB_CLOSE_ON_EXIT=FALSE\n"
"      - DB_USERNAME=sa\n"
"      - DB_PASSWORD=\n"
"    volumes:\n"
"      - operaton-data:/camunda\n"
"    restart: always\n"
"    networks:\n"
"      - npm-network\n"
"\n"
"volumes:\n"
"  operaton-data:\n"
"\n"
"networks:\n"
"  npm-network:\n"
"    external: true\n"
"EOF\n"
"\n"
"docker compose up -d"
msgstr ""

