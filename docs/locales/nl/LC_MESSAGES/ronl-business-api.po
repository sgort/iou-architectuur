msgid "Calling the Business API from a component"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cfrontend-development.md:346
msgid "Example: Evaluating a DMN decision"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cfrontend-development.md:348
msgid ""
"import { businessApi } from \"../services/api\";\n"
"import type { OperatonVariable } from \"@ronl/shared\";\n"
"\n"
"const handleEvaluate = async () => {\n"
"  try {\n"
"    const variables: Record<string, OperatonVariable> = {\n"
"      inkomen: {\n"
"        value: 24000,\n"
"        type: \"Double\",\n"
"      },\n"
"      leeftijd_requirement: {\n"
"        value: true,\n"
"        type: \"Boolean\",\n"
"      },\n"
"    };\n"
"\n"
"    const response = await businessApi.evaluateDecision(\n"
"      \"berekenrechtenhoogtezorg\",\n"
"      variables,\n"
"    );\n"
"\n"
"    if (response.success) {\n"
"      console.log(\"Result:\", response.data.result);\n"
"    }\n"
"  } catch (error) {\n"
"    console.error(\"Evaluation failed:\", error);\n"
"  }\n"
"};"
msgstr ""

