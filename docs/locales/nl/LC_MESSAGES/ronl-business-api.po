msgid "<#assign isMedewerker = (login.username!'') == '__medewerker__'>"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:135
msgid "When `isMedewerker` is true:"
