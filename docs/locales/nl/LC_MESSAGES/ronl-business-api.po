msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-timeline-integration.md:697
msgid "Add address history to timeline:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-timeline-integration.md:699
msgid ""
"// New endpoint: POST /v1/brp/verblijfplaatshistorie\n"
"router.post('/verblijfplaatshistorie', jwtMiddleware, async (req, res) => {\n"
"  // Forward to BRP verblijfplaatshistorie API\n"
"});\n"
"\n"
"// Extract address events\n"
"function extractAddressEvents(verblijfplaatshistorie): BRPEvent[] {\n"
"  return verblijfplaatshistorie.map(vp => ({\n"
"    type: 'address_change',\n"
"    date: new Date(vp.datumVan.datum),\n"
"    label: 'Verhuizing',\n"
"    description: `Verhuisd naar ${vp.verblijfadres.straat}`,\n"
"  }));\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-timeline-integration.md:716
msgid "2. Cached BRP Data"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-timeline-integration.md:718
msgid "Implement Redis caching:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-timeline-integration.md:720
msgid ""
"// Cache BRP responses for 5 minutes\n"
"const cacheKey = `brp:person:${bsn}`;\n"
"const cached = await redis.get(cacheKey);\n"
"\n"
"if (cached) {\n"
"  return JSON.parse(cached);\n"
"}\n"
"\n"
"const data = await brpApi.getPersonByBSN(bsn);\n"
"await redis.setex(cacheKey, 300, JSON.stringify(data)); // 5 min TTL\n"
"return data;"
msgstr ""

