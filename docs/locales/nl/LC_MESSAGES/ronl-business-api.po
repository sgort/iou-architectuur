msgid ""
"import myfeatureRoutes from './myfeature.routes';\n"
"\n"
"router.use('/v1/myfeature', myfeatureRoutes);\n"
"router.use('/api/myfeature', deprecationMiddleware('/v1/myfeature'), "
"myfeatureRoutes);"
