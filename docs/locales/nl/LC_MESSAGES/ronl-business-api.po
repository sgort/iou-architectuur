"import { test, expect } from '@playwright/test';\n"
"\n"
"test.describe('Timeline Navigation', () => {\n"
"  test.beforeEach(async ({ page }) => {\n"
"    // Login\n"
"    await page.goto('http://localhost:5173');\n"
