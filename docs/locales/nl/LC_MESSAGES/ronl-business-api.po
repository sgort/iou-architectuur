#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccicd.md:42
msgid "Backend deployment pipeline"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccicd.md:44
msgid ""
"Push to acc/main\n"
"    ↓\n"
"npm ci (all workspaces)\n"
"    ↓\n"
"Build @ronl/shared\n"
"    ↓\n"
"ESLint (packages/backend)\n"
"    ↓\n"
"tsc (packages/backend) → dist/\n"
"    ↓\n"
"Verify dist/index.js exists\n"
"    ↓\n"
"Prepare deployment package\n"
"  (preserve dist/ structure, add shared, production dependencies)\n"
"    ↓\n"
"[PROD only] Wait for manual approval\n"
"    ↓\n"
"azure/webapps-deploy@v3\n"
"    ↓\n"
"Wait 30 seconds\n"
"    ↓\n"
"Health check: GET /v1/health (5 retries × 10s)\n"
"    ↓\n"
"Verify /v1/health and /v1/dmns return HTTP 200"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccicd.md:73
msgid "Frontend deployment pipeline"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Ccicd.md:75
msgid ""
"Push to acc/main\n"
"    ↓\n"
"npm ci\n"
"    ↓\n"
"npm run build:acc / build:prod\n"
"  (selects .env.acceptance or .env.production)\n"
"    ↓\n"
"Verify dist/ is not empty\n"
"    ↓\n"
"Azure/static-web-apps-deploy@v1 (skip_app_build: true)\n"
"    ↓\n"
"Wait 15 seconds\n"
"    ↓\n"
"Verify HTTP 200 on frontend URL"
msgstr ""

