msgid "Overview"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:7
msgid ""
"The Timeline Navigation feature requires the `preferred_username` field in "
"JWT tokens to map test users to their BSN (Burgerservicenummer). This "
"document explains how to configure Keycloak to include this field."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:11
msgid "Why This Is Needed"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:13
msgid "The Problem"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:15
msgid "Timeline needs to fetch BRP data using a BSN"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:16
msgid "In production, BSN comes from DigiD via SAML assertion"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:17
msgid "In test/ACC, BSN is mapped from Keycloak username"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:18
msgid "JWT token doesn't include username by default"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:20
msgid "The Solution"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:22
msgid ""
"Add a Keycloak Protocol Mapper that includes `username` in the JWT token as "
"`preferred_username`."
msgstr ""

