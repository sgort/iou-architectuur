#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:458
msgid ""
"**Symptoms:** Landing page works, but `/auth` and `/dashboard` return 404."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:460
msgid "**Cause:** `staticwebapp.config.json` missing or not deployed."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:462
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:462"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:464
msgid ""
"# Verify file exists in source\n"
"ls -la packages/frontend/public/staticwebapp.config.json\n"
"\n"
"# File must be in public/ to be copied to dist/ during build\n"
"\n"
"# If missing, create it:\n"
"cat > packages/frontend/public/staticwebapp.config.json << 'EOF'\n"
"{\n"
"  \"navigationFallback\": {\n"
"    \"rewrite\": \"/index.html\",\n"
"    \"exclude\": [\"/assets/*\", \"/*.js\", \"/*.css\", \"/*.json\"]\n"
"  }\n"
"}\n"
"EOF\n"
"\n"
"# Commit and redeploy\n"
"git add packages/frontend/public/staticwebapp.config.json\n"
"git commit -m \"fix: add SPA routing configuration\"\n"
"git push origin acc"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:486
msgid "Environment variables not applied"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:488
msgid "**Symptoms:** App loads but can't connect to Keycloak or API."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:490
msgid "**Cause:** Build-time environment variables not set."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:492
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:492"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:494
msgid ""
"# Check GitHub Secrets are configured\n"
"# Repository → Settings → Secrets and variables → Actions\n"
"\n"
"# Required secrets:\n"
"# - ACC_KEYCLOAK_URL\n"
"# - ACC_API_URL\n"
"\n"
"# Verify workflow uses them:\n"
"# .github/workflows/azure-frontend-acc.yml\n"
"env:\n"
"  VITE_KEYCLOAK_URL: ${{ secrets.ACC_KEYCLOAK_URL }}\n"
"  VITE_API_URL: ${{ secrets.ACC_API_URL }}\n"
"\n"
"# Re-run workflow after fixing"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:511
msgid "CORS errors in browser console"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:513
msgid "**Symptoms:** Browser shows CORS policy errors when calling API."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:515
msgid "**Cause:** Keycloak or API not configured for frontend origin."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:517
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:517"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:519
msgid ""
"# Keycloak: Web Origins should be '+'\n"
"# This inherits all Valid Redirect URIs as allowed origins\n"
"\n"
"# API: Backend must allow frontend origin in CORS config\n"
"# packages/backend/src/index.ts\n"
"app.use(cors({\n"
"  origin: [\n"
"    'https://acc.mijn.open-regels.nl',\n"
"    'https://mijn.open-regels.nl'\n"
"  ],\n"
"  credentials: true\n"
"}));"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:534
msgid "Deployment takes too long or fails"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:536
msgid "**Symptoms:** GitHub Actions workflow runs for 10+ minutes or fails."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:538
msgid "**Cause:** Azure Static Web Apps service issues or incorrect token."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:540
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:540"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:542
msgid ""
"# Check Azure service status\n"
"# Visit: https://status.azure.com/\n"
"\n"
"# Verify deployment token is valid\n"
"# Azure Portal → Static Web App → Deployment tokens\n"
"# Regenerate if needed and update GitHub Secret\n"
"\n"
"# Check workflow logs for specific error\n"
"# GitHub Actions → Failed workflow → View logs\n"
"\n"
"# Common errors:\n"
"# - \"401 Unauthorized\" → Token invalid, regenerate\n"
"# - \"429 Too Many Requests\" → Wait and retry later"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:558
msgid "Build succeeds but app doesn't update"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:560
msgid ""
"**Symptoms:** Deployment completes successfully but changes not visible."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:562
msgid "**Cause:** Browser cache or CDN cache."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:564
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\deployment\\frontend.md:564"
msgid "**Solution:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cfrontend.md:566
msgid ""
"# Hard refresh browser\n"
"# Chrome: Ctrl+Shift+R (Windows/Linux) or Cmd+Shift+R (Mac)\n"
"# Firefox: Ctrl+F5 (Windows/Linux) or Cmd+Shift+R (Mac)\n"
"\n"
"# Check deployed version\n"
"# View source: https://acc.mijn.open-regels.nl\n"
"# Look for timestamp or version comments\n"
"\n"
"# CDN cache usually invalidates within 5 minutes\n"
"# Wait and try again if issue persists"
msgstr ""

