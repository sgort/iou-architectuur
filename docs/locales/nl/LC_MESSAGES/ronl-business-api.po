msgid "**Create roles:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cuser-guide%5Cadding-municipality.md:57
msgid "Under **Realm roles**, add:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cuser-guide%5Cadding-municipality.md:58
