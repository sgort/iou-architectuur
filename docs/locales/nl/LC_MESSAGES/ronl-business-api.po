msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cjwt-claims.md:3
msgid ""
"RONL Business API validates every request against a JWT access token issued "
"by Keycloak. The token contains standard OIDC claims plus custom claims "
"injected via Keycloak protocol mappers."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cjwt-claims.md:7
msgid "Full token example"
