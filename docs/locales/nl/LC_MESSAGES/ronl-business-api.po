#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:216
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\backend-development.md:216"
msgid "JWT validation"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:218
msgid "`auth/jwt.middleware.ts` validates every protected request:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:220
msgid ""
"const authHeader = req.headers.authorization;\n"
"const token = authHeader?.split(' ')[1];\n"
"\n"
"// Fetch JWKS from Keycloak (cached in Redis, TTL 300s)\n"
"const jwks = await fetchJWKS(config.keycloakUrl, config.keycloakRealm);\n"
"const decoded = jwt.verify(token, jwks);\n"
"\n"
"// Validate standard claims\n"
"if (decoded.exp < Date.now() / 1000) {\n"
"  throw new Error('Token expired');\n"
"}\n"
"if (decoded.aud !== config.jwtAudience) {\n"
"  throw new Error('Invalid audience');\n"
"}\n"
"if (!decoded.iss.startsWith(config.keycloakUrl)) {\n"
"  throw new Error('Invalid issuer');\n"
"}\n"
"\n"
"// Attach to request for downstream handlers\n"
"req.user = decoded;"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:243
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\backend-development.md:243"
msgid "Rate limiting"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:245
msgid "Two policies applied in `src/index.ts`:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:247
msgid ""
"import rateLimit from 'express-rate-limit';\n"
"\n"
"// General API: 100 requests per 15 minutes per IP\n"
"const apiLimiter = rateLimit({\n"
"  windowMs: 15 * 60 * 1000,\n"
"  max: 100,\n"
"  message: 'Too many requests from this IP',\n"
"});\n"
"\n"
"// Auth endpoints: 5 requests per 15 minutes per IP\n"
"const authLimiter = rateLimit({\n"
"  windowMs: 15 * 60 * 1000,\n"
"  max: 5,\n"
"  message: 'Too many login attempts',\n"
"});\n"
"\n"
"app.use('/v1', apiLimiter);\n"
"app.use('/v1/auth', authLimiter);"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:268
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\backend-development.md:268"
msgid "CORS"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:270
msgid ""
"import cors from 'cors';\n"
"\n"
"const allowedOrigins = config.corsOrigin.map((o) => o.trim());\n"
"\n"
"const corsOptions: cors.CorsOptions = {\n"
"  origin: (origin, callback) => {\n"
"    if (!origin) { callback(null, true); return; }  // allow server-to-"
"server\n"
"    if (allowedOrigins.includes(origin)) { callback(null, true); return; }\n"
"    callback(new Error(`CORS blocked for origin: ${origin}`));\n"
"  },\n"
"  credentials: true,\n"
"  methods: ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS'],\n"
"  allowedHeaders: ['Content-Type', 'Authorization'],\n"
"};\n"
"\n"
"app.use(cors(corsOptions));\n"
"app.options('*', cors(corsOptions));"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:290
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api\\developer\\backend-development.md:290"
msgid ""
"`CORS_ORIGIN` in `.env` is a comma-separated list. In production it is "
"`https://mijn.open-regels.nl`. In ACC it is `https://acc.mijn.open-"
"regels.nl`. In local development it is `http://localhost:5173`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:292
msgid "Secrets in production (Azure Key Vault)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:294
msgid ""
"Azure App Settings are the standard secrets store (injected as environment "
"variables). For an additional layer, the Key Vault SDK can be used:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:296
msgid ""
"import { SecretClient } from '@azure/keyvault-secrets';\n"
"import { DefaultAzureCredential } from '@azure/identity';\n"
"\n"
"const credential = new DefaultAzureCredential();\n"
"const client = new SecretClient(process.env.KEY_VAULT_URL!, credential);\n"
"\n"
"const dbPassword = await client.getSecret('db-password');"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cbackend-development.md:306
msgid ""
"The App Service managed identity must be granted `Key Vault Secrets User` on "
"the vault."
