#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:1
msgid "Rule Path Syntax"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:3
msgid ""
"The `rule_id_path` path parameter is the primary way to address rules. This "
"page documents the full syntax."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:7
msgid "Structure"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:9
msgid "{RuleSetId}[{delimiter}{RuleId1}[{delimiter}{RuleId2}[...]]]"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:13
msgid "The first segment is always the **Rule Set ID** (10–500 characters)."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:14
msgid ""
"Each subsequent segment is a **Rule ID** from the publication hierarchy."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:15
msgid ""
"The default delimiter is `,` (comma). It can be overridden with "
"`path_delimiter`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:19
msgid "Rule Set ID formats"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:21
msgid "BWB"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:23
msgid ""
"BWBR0015703                         ← current version (valid today)\n"
"BWBR0015703_2025-07-02_latest       ← latest version valid on date\n"
"BWBR0015703_2025-07-01_0            ← specific publication (date + index)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:29
msgid ""
"Pattern: `BWB{rulesetid}_{date}_{index}` where `index` may be a digit or "
"`latest`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:31
msgid "BWB identifiers are always 8 characters in the form `BWBRxxxxxxx`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:33
msgid "CVDR"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:35
msgid ""
"CVDR712517                          ← current version\n"
"CVDR712517_2025-07-02_latest        ← latest version valid on date\n"
"CVDR712517_1                        ← specific indexed version"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:41
msgid ""
"Pattern: `CVD{rulesetid}_{index}` (normalised) where `index` may be a digit "
"or `latest`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:43
msgid "EU CELLAR"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:45
msgid "CFMX483e4752e-f2e5-11e8-9982-01aa75ed71a1.0017.02_DOC_2"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:49
msgid ""
"Pattern: `CFMX4{rulesetid}_{docid}` — no date-based resolution available."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:51
msgid "DMN 1.3 (Operaton)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cuser-guide%5Crule-path-syntax.md:53
msgid "DMN1.3_{deploymentid}R{resourceid}_{date}_{index}"
msgstr ""

