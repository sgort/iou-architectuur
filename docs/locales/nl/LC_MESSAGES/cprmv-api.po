msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:25
msgid "Dutch national law (Basis Wettenbestand)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:25
msgid "`BWBR…`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:25
msgid "**CVDR**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:25
msgid "Dutch municipal and provincial regulations"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:25
