msgid "JSON-LD RDF serialisation"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:52
msgid "`turtle` / `ttl`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:52
msgid "Turtle RDF serialisation"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api%5Cfeatures%5Coverview.md:52
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/cprmv-api\\features\\overview.md:52"
