msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/index.md:21
msgid "**✏️ CPSV Editor — v1.9.3** · *February 2026*"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/index.md:21
msgid "**DMN Syntactic Validation**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/index.md:21
msgid ""
"Inline [DMN validation]{1} immediately after upload: five-layer syntactic "
"checks with severity-coded results (error / warning / info), element "
"references, and line numbers — directly in the DMN file card."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/index.md:21
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/index.md:21"
