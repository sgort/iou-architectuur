#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvocabulary-configuration.md:56
msgid "Entity types"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvocabulary-configuration.md:58
msgid ""
"Defines which RDF types are recognised and which editor section they map to."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvocabulary-configuration.md:60
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor\\developer\\vocabulary-configuration.md:60"
msgid "**Current configuration:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvocabulary-configuration.md:62
msgid ""
"entityTypes: {\n"
"  service: {\n"
"    acceptedTypes: ['cpsv:PublicService', 'cpsv-ap:PublicService'],\n"
"    canonicalType: 'cpsv:PublicService'\n"
"  },\n"
"  organization: {\n"
"    acceptedTypes: ['org:Organization', 'foaf:Organization'],\n"
"    canonicalType: 'org:Organization'\n"
"  },\n"
"  legalResource: {\n"
"    acceptedTypes: ['eli:LegalResource'],\n"
"    canonicalType: 'eli:LegalResource'\n"
"  },\n"
"  temporalRule: {\n"
"    acceptedTypes: ['ronl:TemporalRule'],\n"
"    canonicalType: 'ronl:TemporalRule'\n"
"  },\n"
"  parameter: {\n"
"    acceptedTypes: ['skos:Concept', 'ronl:ParameterWaarde'],\n"
"    canonicalType: 'skos:Concept'\n"
"  }\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvocabulary-configuration.md:87
msgid "**Adding a type to an existing section:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvocabulary-configuration.md:89
msgid ""
"parameter: {\n"
"  acceptedTypes: [\n"
"    'skos:Concept',\n"
"    'ronl:ParameterWaarde',\n"
"    'custom:Parameter'       // ← add here, never remove existing\n"
"  ],\n"
"  canonicalType: 'skos:Concept'\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cvocabulary-configuration.md:100
msgid ""
"Always add new types alongside existing ones. Removing an accepted type "
"breaks import of files that use it."
msgstr ""

