#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:20
msgid "What changed"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:22
msgid "**Old (deprecated):**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:24
msgid ""
"@prefix ronl: <https://regels.overheid.nl/termen/> .\n"
"\n"
"<something>\n"
"    ronl:hasAnalysis <...> ;\n"
"    ronl:hasMethod <...> ;\n"
"    ronl:implements <...> ."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:33
msgid "**New (current):**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:35
msgid ""
"@prefix ronl:  <https://regels.overheid.nl/ontology#> .\n"
"@prefix cprmv: <https://cprmv.open-regels.nl/0.3.0/> .\n"
"\n"
"<something>\n"
"    cprmv:hasAnalysis <...> ;\n"
"    cprmv:hasMethod <...> ;\n"
"    cprmv:implements <...> ."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:47
msgid "Parser configuration"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:49
msgid "The parser registers both namespaces:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:51
msgid ""
"// src/config/vocabularies.config.js\n"
"namespaces: {\n"
"  'https://regels.overheid.nl/ontology#':  ['ronl'],\n"
"  'https://cprmv.open-regels.nl/0.3.0/':  ['cprmv'],\n"
"  'https://regels.overheid.nl/termen/':   ['ronl-legacy'],  // never "
"exported\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:60
msgid "And maps legacy properties to their current equivalents:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:62
msgid ""
"propertyAliases: {\n"
"  'ronl-legacy:hasAnalysis':     'cprmv:hasAnalysis',\n"
"  'ronl-legacy:hasMethod':       'cprmv:hasMethod',\n"
"  'ronl-legacy:implements':      'cprmv:implements',\n"
"  'ronl-legacy:implementedBy':   'cprmv:implementedBy',\n"
"  'ronl-legacy:confidenceLevel': 'cprmv:confidenceLevel',\n"
"  'ronl-legacy:validFrom':       'ronl:validFrom',\n"
"  'ronl-legacy:validUntil':      'ronl:validUntil',\n"
"  'ronl-legacy:extends':         'ronl:extends',\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:75
msgid ""
"The `ronl-legacy` prefix is an internal alias only — it never appears in "
"exported Turtle. Files imported with the old namespace are silently "
"normalised and re-exported with the current namespaces."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:79
msgid "SPARQL query migration"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:81
msgid ""
"When querying across both old and new data, use `OPTIONAL` to handle both "
"namespaces:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/cpsv-editor%5Cdeveloper%5Cronl-namespace-migration.md:83
msgid ""
"PREFIX cprmv: <https://cprmv.open-regels.nl/0.3.0/>\n"
"PREFIX ronl-old: <https://regels.overheid.nl/termen/>\n"
"\n"
"SELECT ?service ?analysis WHERE {\n"
"  ?service a cpsv:PublicService .\n"
"  OPTIONAL { ?service cprmv:hasAnalysis ?analysis }\n"
"  OPTIONAL { ?service ronl-old:hasAnalysis ?analysis }\n"
"}"
msgstr ""

