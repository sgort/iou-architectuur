msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:123
msgid ""
"An `<inputExpression>` has a `typeRef` value that is not a known DMN FEEL "
"type"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:123
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\reference\\dmn-validation-reference.md:123"
msgid "**Rationale**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:123
msgid ""
"Known types are: `string`, `boolean`, `integer`, `long`, `double`, `number`, "
"`date`, and their capitalised variants. An unknown type (e.g. a misspelling "
"or a custom type name) means the type declaration is present but non-"
"functional."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:123
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\reference\\dmn-validation-reference.md:123"
msgid "**Fix**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:123
msgid "Replace the custom or misspelled type with the correct FEEL type name."
msgstr ""

