#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdeployment-postgresql.md:115
msgid "DATABASE_URL=...?sslmode=verify-full"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdeployment-postgresql.md:121
msgid "`DATABASE_URL` not configured"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdeployment-postgresql.md:123
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\developer\\deployment-postgresql.md:123"
msgid "**Symptom:** Log line at startup:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdeployment-postgresql.md:124
msgid "[DB] Skipping migrations — database not configured"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdeployment-postgresql.md:128
msgid ""
"The backend starts successfully but all `/v1/assets/*` endpoints return `503 "
"DB_NOT_CONFIGURED`."
