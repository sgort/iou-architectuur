#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:1
msgid "BPMN Modeler Implementation"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:3
msgid ""
"The BPMN Modeler wraps the `bpmn-js` library in a three-panel React "
"component. This page covers the component structure, the canvas setup "
"decisions, and known rendering issues with their fixes."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:7
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\developer\\bpmn-modeler.md:7"
msgid "Component structure"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:9
msgid ""
"packages/frontend/src/components/BpmnModeler/\n"
"├── BpmnModeler.tsx            main orchestrator, manages selected process "
"state\n"
"├── BpmnCanvas.tsx             bpmn-js canvas wrapper (modeler lifecycle, "
"badge overlays, deploy trigger)\n"
"├── BpmnProperties.tsx         properties panel (right), includes "
"DmnTemplateSelector\n"
"├── ProcessList.tsx            process list (left), CRUD operations\n"
"├── DmnTemplateSelector.tsx    DMN/DRD dropdown for BusinessRuleTask "
"linking\n"
"├── FormTemplateSelector.tsx   Form dropdown for UserTask / StartEvent "
"linking\n"
"├── DocumentTemplateSelector.tsx  Document template dropdown for UserTask "
"linking  ← new in v1.1.0\n"
"└── BpmnModeler.css            custom styles for canvas rendering fixes and "
"badge overlays\n"
"\n"
"packages/frontend/src/\n"
"├── services/\n"
"│   ├── bpmnService.ts         localStorage CRUD for BpmnProcess records\n"
"│   └── formService.ts         localStorage CRUD for FormSchema records "
"(shared with FormEditor)\n"
"└── utils/\n"
"    └── bpmnTemplates.ts       default BPMN XML templates (new process, "
"example)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:30
msgid "Canvas initialisation"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:32
msgid "`BpmnCanvas.tsx` manages the bpmn-js modeler instance lifecycle:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:34
msgid ""
"const modeler = new Modeler({\n"
"  container: containerRef.current,\n"
"  moddleExtensions: {\n"
"    camunda: camundaModdleDescriptor,\n"
"  },\n"
"});\n"
"\n"
"await modeler.importXML(xml);\n"
"const canvas = modeler.get('canvas');\n"
"canvas.zoom('fit-viewport');"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:47
msgid ""
"`camunda-bpmn-moddle` is used instead of an Operaton equivalent because no "
"`operaton-bpmn-moddle` package exists. Operaton accepts both `camunda:` and "
"`operaton:` namespace attributes, so `camunda:` is safe to use and ensures "
"compatibility with the broader Camunda 7 tooling ecosystem."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:51
msgid "Scroll-to-zoom override"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:53
msgid ""
"The bpmn-js default requires `Ctrl+Scroll` to zoom. This was overridden to "
"plain scroll for consistency with the rest of the application:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:55
msgid ""
"const handleWheel = (e: WheelEvent) => {\n"
"  e.preventDefault();\n"
"  const canvas = modelerRef.current?.get('canvas') as any;\n"
"  const currentZoom = canvas.zoom();\n"
"  const delta = e.deltaY > 0 ? -0.1 : 0.1;\n"
"  canvas.zoom(Math.max(0.2, Math.min(4, currentZoom + delta)));\n"
"};\n"
"\n"
"container.addEventListener('wheel', handleWheel, { passive: false });"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:67
msgid ""
"`passive: false` is required so `preventDefault()` is effective on wheel "
"events."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:71
msgid "Rendering artifact fix"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:73
msgid ""
"bpmn-js produces black circles and stray lines during drag operations when "
"SVG layer pointer events conflict. The fix in `BpmnModeler.css`:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:75
msgid ""
".bpmn-container .djs-overlay-container,\n"
".bpmn-container .djs-hit-container,\n"
".bpmn-container .djs-outline-container {\n"
"  pointer-events: none;\n"
"}\n"
"\n"
".bpmn-container .djs-element {\n"
