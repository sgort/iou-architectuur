#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdmn-validator-implementation.md:30
msgid ""
"interface DmnEntry {\n"
"  id: string;           // generated: Date.now()-random\n"
"  name: string;\n"
"  size: number;\n"
"  content: string;      // raw XML string read by FileReader\n"
"  isValidating: boolean;\n"
"  result: ValidationResult | null;\n"
"  error: string | null;\n"
"}"
