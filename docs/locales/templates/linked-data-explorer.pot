"  \"extends\": [\"bpmn:Process\"],\n"
"  \"properties\": [\n"
"    { \"name\": \"ropaRef\", \"isAttr\": true, \"type\": \"String\" }\n"
"  ]\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cropa-records.md:175
msgid ""
"This registers the attribute with the bpmn-js moddle system so it survives "
