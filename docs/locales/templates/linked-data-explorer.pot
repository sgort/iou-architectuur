msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:134
msgid "An `<o>` column in a decision table is missing a `typeRef` attribute"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:134
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\reference\\dmn-validation-reference.md:134"
msgid "**Rationale**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:134
msgid ""
"Without a typed output, consuming systems (including the Linked Data "
"Explorer's chain builder) cannot validate that the output type of one DMN "
"matches the expected input type of the next DMN in a chain. This is a "
"prerequisite for type-safe chain composition."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:134
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\reference\\dmn-validation-reference.md:134"
msgid "**Fix**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:134
msgid "Add `typeRef` to the `<o>` element."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:143
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\reference\\dmn-validation-reference.md:143"
msgid "BIZ-005"
msgstr ""

