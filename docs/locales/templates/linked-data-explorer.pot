#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cuser-guide%5Csparql-queries.md:53
msgid "Writing queries"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cuser-guide%5Csparql-queries.md:55
msgid "The endpoint follows SPARQL 1.1. Key prefixes for DMN discovery:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cuser-guide%5Csparql-queries.md:57
msgid ""
"PREFIX cprmv: <https://cprmv.open-regels.nl/0.3.0/>\n"
"PREFIX cpsv:  <http://www.w3.org/ns/regorg#>\n"
"PREFIX dct:   <http://purl.org/dc/terms/>\n"
"PREFIX skos:  <http://www.w3.org/2004/02/skos/core#>\n"
"PREFIX ronl:  <https://regels.overheid.nl/ontology#>\n"
"PREFIX schema: <http://schema.org/>"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cuser-guide%5Csparql-queries.md:66
msgid "Example — find all DMNs with their input variable counts:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cuser-guide%5Csparql-queries.md:68
msgid ""
"PREFIX cprmv: <https://cprmv.open-regels.nl/0.3.0/>\n"
"PREFIX dct:   <http://purl.org/dc/terms/>\n"
"PREFIX cpsv:  <http://www.w3.org/ns/regorg#>\n"
"\n"
"SELECT ?identifier ?title (COUNT(?input) AS ?inputCount)\n"
"WHERE {\n"
"  ?dmn a cprmv:DecisionModel ;\n"
"       dct:identifier ?identifier ;\n"
"       dct:title ?title .\n"
"  OPTIONAL {\n"
"    ?input a cpsv:Input ;\n"
"           cpsv:isRequiredBy ?dmn .\n"
"  }\n"
"}\n"
"GROUP BY ?identifier ?title\n"
"ORDER BY ?identifier"
msgstr ""

