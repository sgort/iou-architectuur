#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cfeatures%5Cdmn-chain-building.md:48
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\features\\dmn-chain-building.md:48"
msgid "Export"
