msgid "BSN Mapping Logic"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-api-endpoints.md:579
msgid "**Production (with DigiD):**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-api-endpoints.md:580
msgid ""
"// BSN comes from JWT token (DigiD SAML assertion)\n"
"const bsn = user.bsn; // From JWT claim"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-api-endpoints.md:585
msgid "**Test/ACC Environment:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Cbrp-api-endpoints.md:586
msgid ""
"// BSN derived from username or municipality\n"
"function getUserBSN(user) {\n"
"  // 1. Check JWT for BSN (production)\n"
"  if (user.bsn) return user.bsn;\n"
"  \n"
"  // 2. Map by username (test users)\n"
"  const usernameMapping = {\n"
"    'test-citizen-utrecht': '999992235',\n"
"    'test-citizen-amsterdam': '999992235',\n"
"    // ... other mappings\n"
"  };\n"
"  \n"
"  if (user.preferred_username in usernameMapping) {\n"
"    return usernameMapping[user.preferred_username];\n"
"  }\n"
"  \n"
"  // 3. Fallback to municipality mapping\n"
"  const municipalityMapping = {\n"
"    'utrecht': '999992235',\n"
"    'amsterdam': '999992235',\n"
"    // ... other mappings\n"
"  };\n"
"  \n"
"  if (user.municipality in municipalityMapping) {\n"
"    return municipalityMapping[user.municipality];\n"
"  }\n"
"  \n"
"  return null; // No BSN available\n"
"}"
msgstr ""

