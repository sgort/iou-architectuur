msgid ""
"# From project root\n"
"docker compose exec keycloak \\\n"
"  /opt/keycloak/bin/kc.sh import \\\n"
"  --file /opt/keycloak/data/import/ronl-realm.json"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:234
