#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:212
msgid "To export realm configuration including the mapper:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Creferences%5Ckeycloak-timeline-setup.md:214
msgid ""
"# Inside Keycloak container\n"
"/opt/keycloak/bin/kc.sh export \\\n"
"  --dir /tmp/export \\\n"
"  --realm ronl \\\n"
"  --users realm_file\n"
"\n"
"# Copy from container\n"
"docker cp keycloak:/tmp/export/ronl-realm.json ./config/keycloak/"
msgstr ""

