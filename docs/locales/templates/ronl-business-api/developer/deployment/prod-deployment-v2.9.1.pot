#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cprod-deployment-v2.9.1.md:50
msgid ""
"az webapp config appsettings set \\\n"
"  --name ronl-business-api-prod \\\n"
"  --resource-group rg-ronl-prod \\\n"
"  --settings \\\n"
"    DATABASE_URL=\"postgresql://audit_user:<password>@ronl-postgres-"
"prod.postgres.database.azure.com:5432/audit_logs?sslmode=require\" \\\n"
"    DATABASE_POOL_MIN=\"2\" \\\n"
"    DATABASE_POOL_MAX=\"10\" \\\n"
"    EDOCS_BASE_URL=\"\" \\\n"
"    EDOCS_LIBRARY=\"DOCUVITT\" \\\n"
"    EDOCS_USER_ID=\"\" \\\n"
"    EDOCS_PASSWORD=\"\" \\\n"
"    EDOCS_STUB_MODE=\"true\" \\\n"
"    OPERATON_M2M_BASE_URL=\"https://operaton-doc.open-regels.nl/engine-"
"rest\" \\\n"
"    OPERATON_M2M_USERNAME=\"\" \\\n"
"    OPERATON_M2M_PASSWORD=\"\" \\\n"
"    RONL_SPARQL_ENDPOINT=\"\""
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Cprod-deployment-v2.9.1.md:69
msgid ""
"`EDOCS_STUB_MODE=true` keeps eDOCS in stub mode until the `copilot-studio-"
