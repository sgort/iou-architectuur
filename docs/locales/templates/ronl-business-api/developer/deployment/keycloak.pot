#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:125
msgid "Caseworker context banner"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:127
msgid ""
"The `login.ftl` template distinguishes citizen and caseworker login using a "
"sentinel value passed via Keycloak's `login_hint` parameter. When "
"`AuthCallback.tsx` calls `keycloak.login({ loginHint: '__medewerker__' })`, "
"Keycloak populates `login.username` with this sentinel before rendering "
"`login.ftl`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:129
msgid "The template detects the sentinel at the top of the file:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:131
msgid "<#assign isMedewerker = (login.username!'') == '__medewerker__'>"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:135
msgid "When `isMedewerker` is true:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:137
msgid ""
"The page `<header>` section renders **\"Medewerker portaal\"** instead of "
"the default \"Inloggen\" title"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:138
msgid "An indigo context banner is rendered above the form:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:140
msgid ""
"<#if isMedewerker>\n"
"<div id=\"kc-context-banner\" class=\"kc-context-medewerker\">\n"
"    <!-- briefcase SVG icon -->\n"
"    Inloggen als gemeentemedewerker\n"
"</div>\n"
"</#if>"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:149
msgid ""
"The username `<input>` suppresses the sentinel so the caseworker sees an "
"empty field:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/ronl-business-api%5Cdeveloper%5Cdeployment%5Ckeycloak.md:151
msgid ""
"<input ... value=\"<#if !isMedewerker>${(login.username!'')}</#if>\" ... />"
msgstr ""

