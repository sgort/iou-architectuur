msgid ""
"#kc-context-banner {\n"
"  display: flex;\n"
"  align-items: center;\n"
"  gap: 0.5rem;\n"
"  padding: 0.625rem 1rem;\n"
"  margin-bottom: 1.5rem;\n"
"  background: #f0f4ff;\n"
"  border: 1px solid #c7d7fd;\n"
"  border-radius: 8px;\n"
"  color: #3730a3;\n"
"  font-size: 0.875rem;\n"
