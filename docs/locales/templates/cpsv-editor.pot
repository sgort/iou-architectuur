"├── App.js                     # handlePublish() with progress state "
"management\n"
"├── components/\n"
"│   └── PublishDialog.jsx       # Dialog UI: form, progress, success/error "
"states\n"
"└── utils/\n"
"    └── triplydbHelper.js       # TriplyDB API integration"
msgstr ""

