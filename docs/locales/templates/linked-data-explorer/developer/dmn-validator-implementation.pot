#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdmn-validator-implementation.md:90
msgid ""
"router.post('/validate', async (req: Request, res: Response) => {\n"
"  const { content } = req.body as { content?: string };\n"
"\n"
"  if (!content || typeof content !== 'string') {\n"
"    return res.status(400).json({\n"
"      success: false,\n"
"      error: { code: 'INVALID_REQUEST', message: '...' },\n"
"    });\n"
"  }\n"
"\n"
"  const result = await dmnValidationService.validateDmnContent(content);\n"
"\n"
"  res.json({ success: true, data: result, timestamp: new Date().toISOString"
"() });\n"
"});"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cdmn-validator-implementation.md:107
