#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:43
msgid ""
"`hydrateFromServer()` calls `GET /v1/assets/bpmn`, merges the server "
"response with the local readonly examples, writes the merged list back to "
"`localStorage`, and returns it. If the request fails for any reason the "
"existing `localStorage` contents are returned unchanged and a warning is "
"logged."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:45
msgid ""
"This means the editor always starts from local cache (instant render) and "
"then silently updates with authoritative server data within one network "
"round-trip."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:49
msgid "Database schema"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:51
msgid "`process_definitions`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:52
msgid ""
"CREATE TABLE process_definitions (\n"
"  id                     UUID         PRIMARY KEY DEFAULT gen_random_uuid()"
",\n"
"  lde_id                 VARCHAR(255) UNIQUE NOT NULL,\n"
"  bpmn_process_id        VARCHAR(255) NOT NULL,\n"
"  name                   VARCHAR(500) NOT NULL,\n"
"  description            TEXT,\n"
"  xml                    TEXT         NOT NULL,\n"
"  process_role           VARCHAR(20)  NOT NULL DEFAULT 'standalone'\n"
"                           CHECK (process_role IN ('shell', 'subprocess', "
"'standalone')),\n"
"  called_element         VARCHAR(255),\n"
"  linked_dmn_templates   TEXT[]       NOT NULL DEFAULT '{}',\n"
"  status                 VARCHAR(20)  NOT NULL DEFAULT 'wip'\n"
"                           CHECK (status IN ('example', 'wip')),\n"
"  readonly               BOOLEAN      NOT NULL DEFAULT FALSE,\n"
"  schema_version         INTEGER      NOT NULL DEFAULT 1,\n"
"  deployed_at            TIMESTAMPTZ,\n"
"  operaton_url           TEXT,\n"
"  operaton_deployment_id TEXT,\n"
"  deployed_forms         TEXT[]       NOT NULL DEFAULT '{}',\n"
"  deployed_documents     TEXT[]       NOT NULL DEFAULT '{}',\n"
"  language               VARCHAR(2),                         -- v1.6.0\n"
"  organization           VARCHAR(100),                        -- v1.6.0\n"
"  created_at             TIMESTAMPTZ  NOT NULL DEFAULT NOW(),\n"
"  updated_at             TIMESTAMPTZ  NOT NULL DEFAULT NOW()\n"
");\n"
"\n"
"CREATE INDEX idx_pd_bpmn_process_id ON process_definitions (bpmn_process_id)"
";\n"
"CREATE INDEX idx_pd_called_element  ON process_definitions (called_element)\n"
"  WHERE called_element IS NOT NULL;\n"
"CREATE INDEX idx_pd_process_role    ON process_definitions (process_role);\n"
"CREATE INDEX idx_pd_language        ON process_definitions (language)\n"
"  WHERE language IS NOT NULL;\n"
"CREATE INDEX idx_pd_organization    ON process_definitions (organization)\n"
"  WHERE organization IS NOT NULL;"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:89
msgid ""
"`lde_id` is the internal LDE identifier (e.g. `process_1774384869117`). "
"`bpmn_process_id` is the `<process id=\"...\">` value from the BPMN XML — "
"used for subprocess lookup during bundle assembly."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:91
msgid ""
"`language` (ISO 639-1, nullable) and `organization` (open-ended key, "
"nullable) were added in v1.6.0 to drive list-panel grouping and the deploy-"
"time language consistency check; partial indexes skip the common `NULL` "
"case. See [Multilingualism]{1}. The `deployed_*` columns were added in "
"v1.4.0 for the deployment metadata flowback used by `listPublicBundles()`."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:93
msgid "`form_schemas`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:94
msgid ""
"CREATE TABLE form_schemas (\n"
"  id             TEXT        PRIMARY KEY,\n"
"  name           TEXT        NOT NULL,\n"
"  description    TEXT,\n"
"  schema         JSONB       NOT NULL,\n"
"  status         TEXT        DEFAULT 'wip',\n"
"  schema_version INTEGER     NOT NULL DEFAULT 1,\n"
"  language       VARCHAR(2),                  -- v1.6.0\n"
"  organization   VARCHAR(100),                 -- v1.6.0\n"
"  created_at     TIMESTAMPTZ NOT NULL,\n"
"  updated_at     TIMESTAMPTZ NOT NULL\n"
");\n"
"\n"
"CREATE INDEX idx_fs_language     ON form_schemas (language)\n"
"  WHERE language IS NOT NULL;\n"
"CREATE INDEX idx_fs_organization ON form_schemas (organization)\n"
"  WHERE organization IS NOT NULL;"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Casset-storage.md:114
