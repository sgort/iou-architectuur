#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:308
msgid "API call"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:310
msgid "On **Deploy**, `BpmnCanvas.tsx` sends a JSON body to the backend:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:312
msgid ""
"await fetch(`${API_BASE_URL}/api/dmns/process/deploy`, {\n"
"  method: 'POST',\n"
"  headers: { 'Content-Type': 'application/json' },\n"
"  body: JSON.stringify({\n"
"    bpmnXml: xml,\n"
"    deploymentName: processKey,   // from BPMN process/@id\n"
"    forms,                        // [{ id, schema }]\n"
"    subProcesses,                 // [{ filename, xml }]\n"
"    operatonUrl,                  // from modal field\n"
"    operatonUsername,\n"
"    operatonPassword,\n"
"  }),\n"
"});"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:328
msgid "Backend endpoint"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:330
msgid ""
"`POST /api/dmns/process/deploy` (in `dmn.routes.ts`) delegates to "
"`operatonService.deployProcess()`. That method builds a `multipart/form-"
"data` request with each resource appended as a named field matching Camunda "
"Modeler behaviour:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:332
msgid "Main BPMN: field name = `${processKey}.bpmn`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:333
msgid "Subprocess BPMNs: field name = the subprocess filename"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:334
msgid "Forms: field name = `${formId}.form`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:336
msgid ""
"A custom Operaton URL in the request body causes `deployProcess()` to "
"construct a new Axios client targeting that URL, with optional Basic Auth "
"credentials, instead of using the default `OPERATON_BASE_URL` from the "
"backend environment."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:340
msgid "DmnTemplateSelector"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:342
msgid ""
"`DmnTemplateSelector.tsx` loads from two sources in parallel when mounted "
"for a `BusinessRuleTask`:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:344
msgid ""
"const loadOptions = async () => {\n"
"  // Remote: regular DMNs from backend\n"
"  const response = await fetch(`${API_BASE_URL}/v1/dmns?endpoint=${endpoint}"
"`);\n"
"  const dmnArray: DmnModel[] = data.data.dmns;\n"
"\n"
"  // Local: DRD templates from localStorage\n"
"  const userTemplates = getUserTemplates(endpoint);\n"
"  const drdOptions = userTemplates\n"
"    .filter(t => t.isDrd && t.drdEntryPointId)\n"
"    .map(t => ({\n"
"      identifier: t.drdEntryPointId!,\n"
"      title: `${t.name} (DRD)`,\n"
"      isDrd: true,\n"
"      originalChain: t.drdOriginalChain,\n"
"    }));\n"
"\n"
"  setOptions({ drds: drdOptions, dmns: dmnArray });\n"
"};"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:365
msgid ""
"The dropdown renders two `<optgroup>` elements: \"🔗 DRDs (Unified Chains)\" "
"and \"📋 Single DMNs\". Selection auto-populates `camunda:decisionRef` and "
"suggests a `camunda:resultVariable` value (derived from the decision title, "
"camelCased)."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:367
msgid "DmnTemplateSelector pre-selection fix"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:369
msgid ""
"Before v1.0.0, opening the properties panel for a `BusinessRuleTask` that "
"already had `camunda:decisionRef` set would show an empty dropdown. The fix "
"reads `currentDecisionRef` from `businessObject.get('camunda:decisionRef')` "
"and passes it as `selectedDecisionRef` to `DmnTemplateSelector`, which "
"initialises its `useState` from that prop."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:373
msgid "Process persistence"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:375
msgid ""
"`bpmnService.ts` stores processes as `BpmnProcess` records in PostgreSQL via "
"the backend, using `localStorage` as a synchronous read cache. See [Asset "
"Storage]{1} for the full write-through cache and hydration architecture."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:377
msgid ""
"The `BpmnProcess` type includes three relationship fields added in v1.3.0:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:378
msgid ""
"interface BpmnProcess {\n"
"  // ... existing fields ...\n"
"  bpmnProcessId?: string;                               // <process "
"id=\"...\"> from XML\n"
"  processRole?: 'shell' | 'subprocess' | 'standalone';\n"
"  calledElement?: string;                               // parent shell's "
"bpmnProcessId\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:387
msgid "`bpmnProcessId` is extracted from the XML on save using:"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:388
msgid ""
"const extractBpmnProcessId = (xml: string): string => {\n"
"  const match = xml.match(/<(?:bpmn:)?process[^>]+\\bid=\"([^\"]+)\"/);\n"
"  return match?.[1] ?? 'unknown';\n"
"};"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:395
msgid ""
"`ProcessList.tsx` uses `calledElement === shell.bpmnProcessId` to group "
"subprocesses under their parent shell in the hierarchical view."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:397
msgid "Bundle assembly after migration"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:399
msgid ""
"`BpmnCanvas.tsx` resolves subprocess XMLs for deployment by matching "
"`calledElement` values from the active BPMN against stored `BpmnProcess` "
"records. After the PostgreSQL migration the lookup continues to work "
"identically — `hydrateFromServer()` ensures the local cache reflects the "
"database state on mount, so the in-memory lookup in `BpmnService.getProcesses"
"()` always has current data."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cdeveloper%5Cbpmn-modeler.md:401
msgid ""
"The backend additionally exposes `GET /v1/assets/bpmn/by-bpmn-id/"
":bpmnProcessId` for direct server-side subprocess lookup by BPMN process id."
msgstr ""

