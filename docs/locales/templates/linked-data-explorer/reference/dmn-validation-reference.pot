msgid "**Rationale**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:360
msgid ""
"An `<informationRequirement>` with no referenced element is an empty "
"declaration that contributes nothing to the DRD. It may indicate an "
"incomplete authoring step."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:360
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\reference\\dmn-validation-reference.md:360"
msgid "**Fix**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:360
msgid ""
"Add the appropriate `<requiredInput>` or `<requiredDecision>` child, or "
"remove the empty `<informationRequirement>`."
msgstr ""

