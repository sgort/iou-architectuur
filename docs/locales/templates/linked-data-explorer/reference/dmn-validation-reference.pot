msgid "API contract"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:509
msgid "**Endpoint:** `POST /v1/dmns/validate`"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:511
msgid "**Request:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:512
msgid "{ \"content\": \"<xml string — the full DMN file content>\" }"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:516
msgid "**Response (success):**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:517
msgid ""
"{\n"
"  \"success\": true,\n"
"  \"data\": {\n"
"    \"valid\": true,\n"
"    \"parseError\": null,\n"
"    \"layers\": {\n"
"      \"base\":        { \"label\": \"Base DMN\",         \"issues\": [] },\n"
"      \"business\":    { \"label\": \"Business Rules\",   \"issues\": [] },\n"
"      \"execution\":   { \"label\": \"Execution Rules\",  \"issues\": [] },\n"
"      \"interaction\": { \"label\": \"Interaction Rules\",\"issues\": [] },\n"
"      \"content\":     { \"label\": \"Content\",          \"issues\": [] }\n"
"    },\n"
"    \"summary\": { \"errors\": 0, \"warnings\": 0, \"infos\": 1 }\n"
"  },\n"
"  \"timestamp\": \"2026-02-25T14:32:11.000Z\"\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:536
msgid "**Issue object:**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:537
msgid ""
"{\n"
"  \"severity\": \"warning\",\n"
"  \"code\": \"BIZ-009\",\n"
"  \"message\": \"Catch-all rule \\\"DecisionRule_catchall\\\" (all input "
"entries are empty or \\\"-\\\") exists alongside specific rules in a UNIQUE "
"table. For any input that matches a specific rule, both the specific rule "
"and the catch-all fire — violating the UNIQUE hit policy. Consider "
"hitPolicy=\\\"FIRST\\\", or move default logic to an else-branch.\",\n"
"  \"location\": \"<decision id=\\\"beslissing_biz009\\\">\"\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:546
msgid "**Response (parse error — layers 2–5 skipped):**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:547
msgid ""
"{\n"
"  \"success\": true,\n"
"  \"data\": {\n"
"    \"valid\": false,\n"
"    \"parseError\": \"XML is not well-formed: ...\",\n"
"    \"layers\": {\n"
"      \"base\": { \"label\": \"Base DMN\", \"issues\": [{ \"severity\": "
"\"error\", \"code\": \"BASE-PARSE\", ... }] },\n"
"      \"business\":    { \"label\": \"Business Rules\",   \"issues\": [] },\n"
"      \"execution\":   { \"label\": \"Execution Rules\",  \"issues\": [] },\n"
"      \"interaction\": { \"label\": \"Interaction Rules\",\"issues\": [] },\n"
"      \"content\":     { \"label\": \"Content\",          \"issues\": [] }\n"
"    },\n"
"    \"summary\": { \"errors\": 1, \"warnings\": 0, \"infos\": 0 }\n"
"  },\n"
"  \"timestamp\": \"...\"\n"
"}"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:566
msgid "**Response (bad request):**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:567
msgid ""
"{\n"
"  \"success\": false,\n"
"  \"error\": {\n"
"    \"code\": \"INVALID_REQUEST\",\n"
"    \"message\": \"Request body must contain a \\\"content\\\" field with "
"the DMN XML as a string.\"\n"
"  },\n"
"  \"timestamp\": \"...\"\n"
"}"
msgstr ""

