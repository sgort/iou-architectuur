msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:233
msgid ""
"BWB IDs are the persistent identifiers for Dutch legislation on "
"`wetten.overheid.nl`. A malformed value cannot be resolved to a legislation "
"page, breaking the link between the DMN and its legal source."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:233
msgctxt "C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer\\reference\\dmn-validation-reference.md:233"
msgid "**Fix**"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Creference%5Cdmn-validation-reference.md:233
msgid ""
"Use the correct BWB ID. BWB IDs are found in the URL of the legislation on "
"`wetten.overheid.nl`."
msgstr ""

