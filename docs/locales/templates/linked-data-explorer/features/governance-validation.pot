msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cfeatures%5Cgovernance-validation.md:14
msgid "✓ Gevalideerd (green)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cfeatures%5Cgovernance-validation.md:14
msgid ""
"The DMN has been formally validated by a competent authority. Safe for "
"production use."
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cfeatures%5Cgovernance-validation.md:14
msgid "`in-review`"
msgstr ""

