msgid "⏱ In Review (amber)"
msgstr ""

#: C:/Users/gorts01/Development/iou-architectuur/docs/en/linked-data-explorer%5Cfeatures%5Cgovernance-validation.md:14
msgid "Validation is in progress. Use with caution in production."
msgstr ""

